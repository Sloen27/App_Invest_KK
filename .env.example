# Create a read-only token in T-Invest and paste it here.
# Never commit your real token.
T_INVEST_TOKEN=tiu_your_read_only_token_here

# Optional locally, strongly recommended on Vercel.
# Anyone with this password can open your deployed dashboard.
APP_PASSWORD=change_me_to_a_long_random_password

# Optional. Set a long random value on Vercel so sessions stay valid
# even if you rotate the T-Invest token or app password.
APP_SESSION_SECRET=change_me_to_another_long_random_value

# Optional. The default is the public T-Invest REST gateway.
T_INVEST_API_BASE=https://invest-public-api.tinkoff.ru/rest

# Optional. Public MOEX ISS source for the bonds module.
MOEX_ISS_BASE=https://iss.moex.com/iss
MOEX_FETCH_TIMEOUT_MS=12000

# Optional. Change if port 5177 is busy.
PORT=5177
